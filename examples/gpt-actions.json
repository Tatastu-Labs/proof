{
  "openapi": "3.1.0",
  "info": {
    "title": "Tatastu Proof",
    "description": "Stamp content with a permanent, verifiable provenance record. Hash content locally (SHA-256), send the fingerprint, get a public verify URL back. Verification is free forever, no auth required.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://proof.tatastu.dev" }
  ],
  "paths": {
    "/keys": {
      "post": {
        "operationId": "createFreeKey",
        "summary": "Create a free API key",
        "description": "Mints a free API key with no email or account required. Returns the secret key — store it, it's shown only once. Free keys include 5 stamps per calendar month.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "label": { "type": "string", "description": "Optional label for this key (e.g. 'chatgpt-plugin')", "maxLength": 80 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Key created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "secret": { "type": "string", "description": "The API key (pk_...). Shown once — store it now." },
                    "creatorId": { "type": "string" },
                    "plan": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/proof": {
      "post": {
        "operationId": "stampContent",
        "summary": "Stamp a content hash",
        "description": "Records a SHA-256 content fingerprint with your creator identity and a timestamp. Hash the content bytes locally — the content itself never leaves the client. Returns a permanent verify URL.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["contentHash"],
                "properties": {
                  "contentHash": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$",
                    "description": "SHA-256 hex digest of the exact content bytes (64 lowercase hex chars)"
                  },
                  "title": {
                    "type": "string",
                    "maxLength": 300,
                    "description": "Optional human-readable title"
                  },
                  "visibility": {
                    "type": "string",
                    "enum": ["public", "private"],
                    "default": "public",
                    "description": "public: title appears on the verify page. private: only the hash is shown."
                  },
                  "contentType": {
                    "type": "string",
                    "description": "Optional MIME type (e.g. text/markdown, image/png)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Stamp created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "proofId": { "type": "string" },
                    "verifyUrl": { "type": "string", "description": "Public URL anyone can open to verify this stamp" },
                    "byline": { "type": "string", "description": "Attribution string to embed in the content" },
                    "badgeEmbed": { "type": "string", "description": "HTML snippet for an embeddable proof badge" },
                    "status": { "type": "string", "enum": ["SIGNED", "ANCHORED", "CONFIRMED", "REVOKED"] },
                    "signedAt": { "type": "integer", "description": "Unix ms timestamp of the stamp" }
                  }
                }
              }
            }
          },
          "402": {
            "description": "Quota exhausted or payment required"
          }
        }
      }
    },
    "/verify": {
      "post": {
        "operationId": "verifyContent",
        "summary": "Verify a content hash",
        "description": "Returns all stamps for the given SHA-256 hash, earliest anchored first. Free and unauthenticated — no API key needed.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["contentHash"],
                "properties": {
                  "contentHash": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$",
                    "description": "SHA-256 hex digest to look up"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contentHash": { "type": "string" },
                    "proofs": {
                      "type": "array",
                      "description": "All stamps for this hash, earliest anchored first",
                      "items": {
                        "type": "object",
                        "properties": {
                          "proofId": { "type": "string" },
                          "creatorId": { "type": "string" },
                          "status": { "type": "string" },
                          "signedAt": { "type": "integer" },
                          "verifyUrl": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "pk_...",
        "description": "Free API key from https://tatastu.dev/proof. 5 stamps/month free."
      }
    }
  }
}
